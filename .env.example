# =============================================================================
# Assistant OS - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores.
# NUNCA commits el archivo .env real al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Claude / Anthropic (CODE module — read-only executor) - REQUERIDO para CODE
# -----------------------------------------------------------------------------
# API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model for CODE_EXPLAIN / CODE_REVIEW (default: claude-haiku-4-5-20251001)
# CODE_REVIEW_MODEL=claude-haiku-4-5-20251001
# Model for CODE_FIX / CODE_CREATE preview (default: claude-haiku-4-5-20251001; use sonnet for better diffs)
# CODE_PROPOSE_MODEL=claude-haiku-4-5-20251001
# CODE_PROPOSE_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Authority Artifact signing — REQUERIDO en producción
# -----------------------------------------------------------------------------
# HMAC-SHA256 secret used to sign and verify authority artifacts.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# NEVER share, commit, or log this value.
# In production: set this variable. Do NOT set ASSISTANT_OS_DEV_MODE.
ASSISTANT_OS_AUTHORITY_ARTIFACT_SECRET=replace_with_generated_hex_secret
#
# Local / CI development only — allows dev-default signing key.
# Set to exactly "1" to enable; any other value (including "true") is rejected.
# ASSISTANT_OS_DEV_MODE=1   # <-- uncomment for local dev/CI only

# -----------------------------------------------------------------------------
# MSO / Local LLM — cognitive advisory layer (all off by default)
# -----------------------------------------------------------------------------
# Step 1: Enable MSO and configure the local model server
# MSO_ENABLED=false
# LOCAL_LLM_PROVIDER=llamacpp          # "llamacpp" or "ollama"
# LOCAL_LLM_BASE_URL=http://127.0.0.1:8081   # llamacpp default port
# LOCAL_LLM_MODEL=                     # model name (llamacpp: leave empty; ollama: e.g. llama3.2:3b-instruct)
# LOCAL_LLM_TIMEOUT_SECONDS=4.0
#
# Step 2: Expose the cognition layer to the UI (requires Step 1 to be set)
# ASSISTANT_LOCAL_LLM_ENABLED=false    # set true to allow probe + UI reporting
# ASSISTANT_UI_SHOW_COGNITION=false    # set true to render cognitive widgets in the UI

# -----------------------------------------------------------------------------
# Obsidian Vault — read-only semantic context layer (optional)
# -----------------------------------------------------------------------------
# Set to the absolute path of your Obsidian vault root directory.
# Leave empty (default) to disable vault context entirely.
# ASSISTANT_OS_VAULT_PATH=/Users/jorge/Documents/MyVault
ASSISTANT_OS_VAULT_PATH=

# -----------------------------------------------------------------------------
# MACHINE_OPERATOR / OpenClaw Gateway (Windows-side boundary preparation)
# -----------------------------------------------------------------------------
# Gateway base URL. Accepts ws(s) or http(s); the adapter normalizes to the
# execute endpoint internally.
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18790
# OPENCLAW_TIMEOUT_SECONDS=5.0
#
# Transport-auth hook for future Windows -> Ubuntu/OpenClaw trust hardening.
# Supported modes:
#   disabled     - no auth header sent (current default)
#   header_token - send one configured header with the exact value loaded from
#                  the env var named by OPENCLAW_GATEWAY_AUTH_TOKEN_ENV_VAR
# OPENCLAW_GATEWAY_AUTH_MODE=disabled
# OPENCLAW_GATEWAY_AUTH_HEADER_NAME=X-OpenClaw-Token
# OPENCLAW_GATEWAY_AUTH_TOKEN_ENV_VAR=OPENCLAW_GATEWAY_AUTH_TOKEN
# OPENCLAW_GATEWAY_AUTH_TOKEN=replace_me_for_future_linux_integration
#
# MACHINE_OPERATOR secrets remain disabled in-repo. This transport token is for
# future boundary authentication only; it does not enable secret-backed browser
# execution.

# -----------------------------------------------------------------------------
# Notion Integration (WORK module) - REQUERIDO
# -----------------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORK_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Webhook Server - REQUERIDO para API externa
# -----------------------------------------------------------------------------
# Token de autenticación para el webhook (generar con: openssl rand -base64 48)
WEBHOOK_TOKEN=tu_token_seguro_aqui
# Host y puerto (opcional, defaults: 0.0.0.0:8787)
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8787

# -----------------------------------------------------------------------------
# Google Sheets Integration (FIN module) - REQUERIDO para gastos
# -----------------------------------------------------------------------------
# Ruta al archivo JSON de service account (default: secrets/service-account.json)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/service-account.json
# ID del spreadsheet (de la URL: docs.google.com/spreadsheets/d/{ID}/...)
SHEETS_SPREADSHEET_ID=tu_spreadsheet_id_aqui
# Nombre de la pestaña/hoja (default: Gastos)
# SHEETS_TAB_NAME=Gastos

# -----------------------------------------------------------------------------
# Admin API token (opcional, para acceso localhost)
# -----------------------------------------------------------------------------
ASSISTANT_API_TOKEN=tu_token_de_admin_aqui

# -----------------------------------------------------------------------------
# GitHub Integration (CodeOps module) - REQUERIDO para PRs
# -----------------------------------------------------------------------------
# Personal access token con permisos: repo (o public_repo para repos públicos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# CodeOps Configuration
# -----------------------------------------------------------------------------
# Lista de repositorios permitidos (comma-separated). Vacío = permitir todos (dev)
# CODEOPS_ALLOWED_REPOS=owner/repo1,owner/repo2
# Activar modo live para ejecutar operaciones reales de git/GitHub
# CODEOPS_LIVE_MODE=false

# -----------------------------------------------------------------------------
# Sandbox / Runner — controlled code execution (requires Docker)
# -----------------------------------------------------------------------------
# Execution mode for CODE domain apply operations.
#   "stub" (default) — no real execution, safe for development and CI without Docker.
#   "real"           — execute code in an ephemeral Docker container.
# NEVER set to "real" without Docker installed and access controls verified.
# APPLY_EXECUTION_MODE=stub

# Hard timeout for container executions (seconds). Default: 30.
# RUNNER_TIMEOUT_SECONDS=30

# Docker resource caps per container. Adjust for your hardware.
# RUNNER_MEMORY_LIMIT=128m
# RUNNER_CPU_LIMIT=0.5

# Base Docker image — MUST be pre-pulled; no dynamic builds allowed.
# RUNNER_BASE_IMAGE=python:3.11-slim
