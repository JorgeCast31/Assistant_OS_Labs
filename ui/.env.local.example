# Copy to .env.local and adjust for your environment
# For Vercel deployment, set these in Project Settings > Environment Variables

# Public API URL (exposed to browser - use HTTPS in production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public Webhook URL (exposed to browser for health checks only)
NEXT_PUBLIC_WEBHOOK_BASE_URL=http://localhost:8787

# Server-side Webhook URL (used by API routes, can be internal/private)
WEBHOOK_BASE_URL=http://localhost:8787

# Server-side authentication token (keep secret, never expose to client)
ASSISTANT_TOKEN=your-secret-token-here
