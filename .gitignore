# =============================================================================
# Assistant OS - .gitignore
# =============================================================================

#MSO related
assistant_os/memory/mso_store/


# ----- Frontend build/cache -----
ui/out/
ui/.turbo/
ui/.vercel/
ui/.next/
ui/node_modules/
ui/tsconfig.tsbuildinfo

# ----- Python tooling cache -----
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# ----- Local databases / sqlite -----
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ----- OS / temp -----
*.tmp
*.temp

# ----- Secrets & Environment -----
.env
.env.local
.env.*.local
*.pem
*.key
*service-account*.json
*credentials*.json
client_secret*.json
assistant_os/memory/context_store.json
var/
node_modules/
.next/
tools/
.ssh/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.eggs/
*.egg-info/
*.egg
dist/
build/

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
scratch/
scripts/**
scripts/**
!scripts/windows_openclaw_sprint1_validate.bat
src/crear_modulo_test.py

# ----- Generated/Runtime -----
tests_generated/
*.log
*.ndjson
var/runner/executions/
var/runner/**/*.log
logs/*.log
logs/*.ndjson

# ----- Memory (runtime state, logs) -----
assistant_os/memory/state.json
assistant_os/memory/log.ndjson
assistant_os/memory/taxonomy_cache.json
assistant_os/memory/*.db
assistant_os/memory/*.db-shm
assistant_os/memory/*.db-wal
assistant_os/memory/*.ndjson
assistant_os/memory/*_cache.json
state/run_state.json
tools/launcher/launcher_config.json

# ----- Scratch outputs (auto-generated module files) -----
src/crea_modulo_*
src/crear_modulo_test_*

# ----- Seeds (real data, allow templates) -----
seeds/*.json
!seeds/*.example.json
!seeds/*.template.json

# ----- IDE / Editor -----
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# ----- Misc -----
Thumbs.db
*.bak
.claude/
.claude/worktrees/
assistant_os/.claude/
.codex
.worktrees/

# Claude / artifacts
CHAT.md
FINAL_REPORT.md
PHASE1_BASELINE.md
TASK_*.md
WORKLOG.md
agent_contract.md

# accidental root files
chat_core.py
code_api.py
webhook_server.py

# Logs de ejecución Claude / debug
*.trace
*.debug
*.dump

.assistant_os_state.json
.assistant_os_state.json.tmp
