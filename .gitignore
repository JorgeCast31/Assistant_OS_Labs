# =============================================================================
# Assistant OS - .gitignore
# =============================================================================

# ----- Frontend build/cache -----
ui/out/
ui/.turbo/
ui/.vercel/

# ----- Python tooling cache -----
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# ----- Local databases / sqlite -----
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ----- OS / temp -----
*.tmp
*.temp

# ----- Secrets & Environment -----
.env
.env.local
.env.*.local
*.pem
*.key
*service-account*.json
*credentials*.json
client_secret*.json
assistant_os/memory/context_store.json
var/
node_modules/
.next/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.eggs/
*.egg-info/
*.egg
dist/
build/

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
scratch/
scripts/
src/crear_modulo_test.py

# ----- Generated/Runtime -----
tests_generated/
*.log
*.ndjson

# ----- Memory (runtime state, logs) -----
assistant_os/memory/state.json
assistant_os/memory/log.ndjson
assistant_os/memory/taxonomy_cache.json

# ----- Scratch outputs (auto-generated module files) -----
src/crea_modulo_*
src/crear_modulo_test_*

# ----- Seeds (real data, allow templates) -----
seeds/*.json
!seeds/*.example.json
!seeds/*.template.json

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ----- Misc -----
Thumbs.db
*.bak
.claude/
assistant_os/.claude/

# Claude / artifacts
CHAT.md
FINAL_REPORT.md
PHASE1_BASELINE.md
TASK_*.md
WORKLOG.md
agent_contract.md

# accidental root files
chat_core.py
code_api.py
webhook_server.py

# Logs de ejecución Claude / debug
*.trace
*.debug
*.dump